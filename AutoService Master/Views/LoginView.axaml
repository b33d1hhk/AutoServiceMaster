<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AutoService_Master.ViewModels"
             x:DataType="vm:LoginViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AutoService_Master.Views.LoginView">
    <Grid Background="#1E1E1E">
        <Border Background="#252526" CornerRadius="12" Padding="40" 
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="350" BoxShadow="0 10 30 0 #000000">
            <StackPanel Spacing="20">
                <TextBlock Text="Авторизація" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                
                <StackPanel>
                    <TextBlock Text="Логін" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Username}" Watermark="Введіть логін" Padding="10"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Пароль" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Password}" PasswordChar="•" Watermark="Введіть пароль" Padding="10"/>
                </StackPanel>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" 
                           HorizontalAlignment="Center" FontWeight="SemiBold"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button Content="Увійти" Command="{Binding LoginCommand}"
                        Background="#4AA9FF" Foreground="White" FontWeight="Bold" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10" CornerRadius="6" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

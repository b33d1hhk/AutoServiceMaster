<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:AutoService_Master.Models"
             xmlns:vm="using:AutoService_Master.ViewModels"
             x:DataType="vm:OrdersViewModel"
             x:Class="AutoService_Master.Views.OrdersView">

	<Grid ColumnDefinitions="*, 300" Margin="20">

		<Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,20,0">
			<TextBlock Grid.Row="0" Text="{DynamicResource Txt_Orders}" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

			<ListBox Grid.Row="1" ItemsSource="{Binding Orders}" Background="Transparent" BorderThickness="0">
				<ListBox.ItemTemplate>
					<DataTemplate x:DataType="models:Order">
						<Border Background="#2D2D30" CornerRadius="8" Margin="0,0,0,10" Padding="15">
							<Grid ColumnDefinitions="1.5*, 2*, 1*, 1*, Auto">
								<StackPanel Grid.Column="0" VerticalAlignment="Center">
									<TextBlock Text="{Binding ClientName}" FontWeight="Bold" FontSize="16" Foreground="White"/>
									<TextBlock Text="{DynamicResource ClientWord}" FontSize="12" Foreground="#888888"/>
								</StackPanel>

								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="{Binding Description}" Foreground="#E0E0E0" TextWrapping="Wrap"/>
									<TextBlock Text="{DynamicResource DescWord}" FontSize="12" Foreground="#888888"/>
								</StackPanel>

								<StackPanel Grid.Column="2" VerticalAlignment="Center">
									<TextBlock Text="{Binding Price, StringFormat='₴ {0}'}" Foreground="#47D16E" FontWeight="Bold"/>
									<TextBlock Text="{DynamicResource OrderPrice}" FontSize="12" Foreground="#888888"/>
								</StackPanel>

								<StackPanel Grid.Column="3" VerticalAlignment="Center">
									<TextBlock Text="{Binding Status}" Foreground="#FFB020" FontWeight="SemiBold"/>
									<TextBlock Text="{DynamicResource StatusWord}" FontSize="12" Foreground="#888888"/>
								</StackPanel>

								<StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
									<Button Content="❌" Background="Transparent" ToolTip.Tip="Видалити"
                                            IsVisible="{Binding $parent[UserControl].((vm:OrdersViewModel)DataContext).IsAdmin}"
                                            Command="{Binding $parent[UserControl].((vm:OrdersViewModel)DataContext).DeleteOrderCommand}"
                                            CommandParameter="{Binding}"/>
								</StackPanel>
							</Grid>
						</Border>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</Grid>

		<Border Grid.Column="1" Background="#252526" CornerRadius="10" Padding="20" VerticalAlignment="Top">
			<StackPanel Spacing="15">
				<TextBlock Text="{DynamicResource NewOrder}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

				<StackPanel>
					<TextBlock Text="{DynamicResource SelectClientReq}" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>
					<ComboBox ItemsSource="{Binding Clients}"
                              SelectedItem="{Binding SelectedClient}"
                              HorizontalAlignment="Stretch" Background="#1E1E1E">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding FullName}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</StackPanel>

				<StackPanel>
					<TextBlock Text="{DynamicResource OrderDescReq}" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>
					<TextBox Text="{Binding NewDescription}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Background="#1E1E1E" Foreground="White" BorderBrush="#3E3E42"/>
				</StackPanel>

				<StackPanel>
					<TextBlock Text="{DynamicResource OrderPrice}" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>
					<TextBox Text="{Binding NewPrice}" Background="#1E1E1E" Foreground="White" BorderBrush="#3E3E42"/>
				</StackPanel>

				<Button Content="{DynamicResource SaveOrderBtn}"
                        Command="{Binding SaveOrderCommand}"
                        Background="#4AA9FF" Foreground="White"
                        FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10" Margin="0,15,0,0" CornerRadius="6"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
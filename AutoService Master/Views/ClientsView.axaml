<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AutoService_Master.Views.ClientsView">
    <StackPanel Margin="20">
        <TextBlock Text="Клієнти" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
        <TextBlock Text="Тут буде таблиця клієнтів та кнопка 'Додати клієнта'." Foreground="#AAAAAA"/>
    </StackPanel>
</UserControl>

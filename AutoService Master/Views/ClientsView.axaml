<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AutoService_Master.ViewModels"
             x:DataType="vm:ClientsViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AutoService_Master.Views.ClientsView">
    
    <Grid RowDefinitions="Auto, *" Margin="20">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <TextBlock Grid.Column="0" 
                       Text="Клієнти" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" 
                    Content="+ Додати клієнта" 
                    Command="{Binding AddClientCommand}"
                    Background="#4AA9FF" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Padding="15,10" 
                    CornerRadius="6"/>
        </Grid>
        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding Clients}" 
                 Background="Transparent" 
                 BorderThickness="0">
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2D2D30" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                        <Grid ColumnDefinitions="2*, 1.5*, 2*, Auto">
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="16" Foreground="White"/>
                                <TextBlock Text="ПІБ" FontSize="12" Foreground="#888888"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PhoneNumber}" Foreground="#E0E0E0"/>
                                <TextBlock Text="Телефон" FontSize="12" Foreground="#888888"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CarInfo}" Foreground="#4AA9FF" FontWeight="SemiBold"/>
                                <TextBlock Text="Автомобіль" FontSize="12" Foreground="#888888"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Button Content="✏️" Background="Transparent" ToolTip.Tip="Редагувати"/>
                                <Button Content="❌" Background="Transparent" ToolTip.Tip="Видалити"/>
                            </StackPanel>
                            
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
    </Grid>
</UserControl>
